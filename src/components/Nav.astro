---
const links = [
  { href: '/',         label: 'Home' },
  { href: '/work',     label: 'Work' },
  { href: '/projects', label: 'Projects' },
  { href: '/research', label: 'Research' },
  { href: '/cv',       label: 'CV' },
];
const current = Astro.url.pathname;
---
<header class="fixed top-0 inset-x-0 z-40 bg-[#fdf6f0]/80 backdrop-blur-sm border-b border-[#f5cfc3]/50">
  <nav class="max-w-3xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="font-semibold text-[#2c1f1e] tracking-tight hover:text-[#d4756b] transition-colors">
      Bianca Bodo
    </a>
    <ul class="flex gap-6 text-sm">
      {links.filter(l => l.href !== '/').map(l => (
        <li>
          <a
            href={l.href}
            class={[
              'transition-colors hover:text-[#d4756b]',
              current.startsWith(l.href)
                ? 'text-[#d4756b] font-medium'
                : 'text-[#5a4040]'
            ].join(' ')}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
