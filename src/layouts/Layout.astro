---
import Nav from '../components/Nav.astro';
import Petals from '../components/Petals.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bianca Bodo',
  description = 'ML practitioner — JPMorganChase · Alpine F1 · UCL',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === 'Bianca Bodo' ? title : `${title} — Bianca Bodo`}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-5Q8XLW1GMB"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-5Q8XLW1GMB');
    </script>
  </head>
  <body class="min-h-screen">
    <Petals />
    <Nav />
    <main class="max-w-3xl mx-auto px-6 pt-24 pb-20">
      <slot />
    </main>
    <footer class="text-center text-xs text-[#9a7878] py-8">
      © {new Date().getFullYear()} Bianca Bodo
    </footer>
  </body>
</html>
