---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <section class="min-h-[70vh] flex flex-col justify-center">
    <div class="flex items-start gap-6 mb-10">
      <img
        src="/bianca_bodo.jpg"
        alt="Bianca Bodo"
        class="w-24 h-24 rounded-full object-cover border-2 border-[#f0b8c4] shadow-sm flex-shrink-0 mt-1"
      />
      <div>
        <h1 class="text-4xl font-semibold text-[#2c1f1e] mb-2 leading-tight">
          Bianca Bodo
        </h1>
        <p class="text-[#d4756b] font-medium text-lg">
          ML Engineer &amp; Data Scientist
        </p>
      </div>
    </div>

    <p class="text-[#5a4040] text-lg leading-relaxed mb-6 max-w-xl">
      I build production ML systems — from RAG pipelines and LLM infrastructure to
      statistical models in high-stakes environments. Currently at
      <span class="text-[#2c1f1e] font-medium">JPMorganChase</span> in London.
    </p>

    <p class="text-[#9a7878] leading-relaxed mb-10 max-w-xl">
      Background in engineering and architectural design from UCL, with stints at
      Alpine F1 and Bosch. I'm interested in interpretable AI, causal reasoning,
      and human-centred systems.
    </p>

    <div class="flex flex-wrap gap-3">
      <a href="/work" class="px-5 py-2 bg-[#d4756b] text-white rounded-full text-sm font-medium hover:bg-[#b85a52] transition-colors">
        Work
      </a>
      <a href="/cv" class="px-5 py-2 border border-[#edaa97] text-[#d4756b] rounded-full text-sm font-medium hover:bg-[#fae8e0] transition-colors">
        CV
      </a>
      <a href="mailto:bianca.bodo20@gmail.com" class="px-5 py-2 border border-[#edaa97] text-[#d4756b] rounded-full text-sm font-medium hover:bg-[#fae8e0] transition-colors">
        Email
      </a>
      <a href="https://github.com/biancabodo" target="_blank" rel="noopener" class="px-5 py-2 border border-[#edaa97] text-[#d4756b] rounded-full text-sm font-medium hover:bg-[#fae8e0] transition-colors">
        GitHub
      </a>
      <a href="https://www.linkedin.com/in/bianca-bodo" target="_blank" rel="noopener" class="px-5 py-2 border border-[#edaa97] text-[#d4756b] rounded-full text-sm font-medium hover:bg-[#fae8e0] transition-colors">
        LinkedIn
      </a>
    </div>
  </section>
</Layout>
